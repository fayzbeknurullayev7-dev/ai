GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
REDIS_URL=redis://localhost:6379
APP_ENV=development
# Xotira backendi: "memory" (RAM, standart) yoki "redis" (persistent).
# docker-compose buni avtomatik "redis" qiladi (REDIS_URL=redis://redis:6379).
MEMORY_BACKEND=memory
# Ixtiyoriy: web_search uchun. Bo'sh qoldirsangiz DuckDuckGo (keysiz) ishlatiladi.
TAVILY_API_KEY=
# RAG / bilim bazasi embeddinglari: GEMINI_API_KEY o'rnatilgan bo'lsa haqiqiy
# semantik Gemini embeddings, aks holda kalitsiz offline HashingEmbedder ishlatiladi.
# JWT autentifikatsiya — PRODUCTION'da albatta kuchli tasodifiy qiymatga o'zgartiring:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=dev-insecure-secret-change-me
JWT_EXPIRES_IN=86400
